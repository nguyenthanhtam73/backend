# DaDiary backend — copy to `.env` at repo root.
# Env vars use prefix DADIARY_* (see internal/config/config.go).

DADIARY_ENV=development
DADIARY_HTTP_PORT=8080
DADIARY_HTTP_READ_TIMEOUT=2m
DADIARY_HTTP_WRITE_TIMEOUT=12m

# Database (local Postgres on 5432, or Docker on 5433)
DADIARY_DATABASE_URL=postgres://dadiary:dadiary@localhost:5432/dadiary?sslmode=disable

# JWT (strong secret in production, e.g. openssl rand -base64 64)
DADIARY_JWT_SECRET=change-me-in-production-use-long-random-string

# AI (optional)
DADIARY_OPENAI_API_KEY=
DADIARY_OPENAI_VISION_MODEL=gpt-4o
DADIARY_ANTHROPIC_API_KEY=
DADIARY_ANTHROPIC_MODEL=
