# DaDiary backend — copy to `.env` at repo root.
# Env vars use prefix DADIARY_* (see internal/config/config.go).

DADIARY_ENV=development
DADIARY_HTTP_PORT=8080
DADIARY_HTTP_READ_TIMEOUT=2m
DADIARY_HTTP_WRITE_TIMEOUT=12m

# Database (local Postgres on 5432, or Docker on 5433)
DADIARY_DATABASE_URL=postgres://dadiary:dadiary@localhost:5432/dadiary?sslmode=disable

# JWT (strong secret in production, e.g. openssl rand -base64 64)
DADIARY_JWT_SECRET=change-me-in-production-use-long-random-string

# --- Hybrid AI strategy (final) ---
#
# Vision (skin photos + moderation): ALWAYS OpenAI — set vision model here.
#   gpt-4o (default) or gpt-4o-mini for lower cost.
DADIARY_OPENAI_API_KEY=
DADIARY_OPENAI_MODEL=gpt-4o
DADIARY_OPENAI_VISION_MODEL=gpt-4o

# Text coaching (daily feedback, routine suggest, starter routine): Claude Sonnet PRIMARY.
# Auto-fallback to DADIARY_OPENAI_MODEL when key missing, Claude errors, or timeout.
DADIARY_ANTHROPIC_API_KEY=
# Optional Sonnet model — default claude-sonnet-4-6.
# Alternatives: claude-sonnet-4-20250514, claude-3-5-sonnet-20241022 (may 404 on some accounts).
DADIARY_ANTHROPIC_MODEL=
# Comma-separated admin emails for /api/v1/admin/* (feedback console).
DADIARY_ADMIN_EMAILS=

# --- Web Push (VAPID) — Phase 2 send ---
#
# Generate a key pair once:
#   npx web-push generate-vapid-keys
#   # or from Go: webpush.GenerateVAPIDKeys()
#
# Put the SAME public key in frontend/.env.local as NEXT_PUBLIC_VAPID_PUBLIC_KEY
# so browser subscribe() matches the server that will send.
DADIARY_VAPID_PUBLIC_KEY=
DADIARY_VAPID_PRIVATE_KEY=
# Optional VAPID contact (mailto: or https:). Default: mailto:noreply@dadiary.app
# DADIARY_VAPID_SUBJECT=mailto:noreply@dadiary.app

# --- Daily Check-in Reminder (background job) ---
# Fires once per day after Hour:Minute in Asia/Ho_Chi_Minh (same calendar as
# streak / check-in). Host TZ is optional; job hardcodes streaktime.Location.
# Optional: TZ=Asia/Ho_Chi_Minh so other logs/tools also show VN wall time.
# DADIARY_DAILY_REMINDER_ENABLED=true
DADIARY_DAILY_REMINDER_HOUR=20
DADIARY_DAILY_REMINDER_MINUTE=0

# --- Subscription lifecycle (trial + grace) ---
# TrialDays clamped to [7, 14]; GraceDays to [3, 7].
# DADIARY_SUBSCRIPTION_TRIAL_DAYS=7
# DADIARY_SUBSCRIPTION_GRACE_DAYS=3

# --- SePay Payment Gateway (Premium checkout) ---
# Currently SANDBOX only. For production: ENV=production + live MERCHANT/SECRET.
DADIARY_SEPAY_ENV=sandbox
DADIARY_SEPAY_MERCHANT_ID=SP-TEST-NT956599
DADIARY_SEPAY_SECRET_KEY=spsk_test_UHoXRUQEfLBChDYghS6AE8B6V9HQpErZ
# Web app (https://dadiary.vn) — used to fill callback URLs when the three below are empty.
DADIARY_PUBLIC_WEB_URL=https://dadiary.vn
DADIARY_SEPAY_SUCCESS_URL=https://dadiary.vn/payment/success
DADIARY_SEPAY_ERROR_URL=https://dadiary.vn/payment/error
DADIARY_SEPAY_CANCEL_URL=https://dadiary.vn/payment/cancel
# Public API host (Railway). Paste this IPN URL into SePay dashboard:
#   POST https://backend-production-bfaa.up.railway.app/api/v1/payment/sepay/webhook
# Auth: X-Secret-Key = DADIARY_SEPAY_SECRET_KEY (sandbox secret above)
DADIARY_PUBLIC_API_URL=https://backend-production-bfaa.up.railway.app
# Full step-by-step: backend/docs/SEPAY_DEPLOY_CHECKLIST.md

# --- Ops alerts (Payment / Subscription monitoring) ---
# Console logs always emit (no cooldown). Remote Slack/Telegram optional.
# Auto-enabled when a webhook or Telegram pair is set; override with:
# DADIARY_ALERT_ENABLED=false
# Slack Incoming Webhook (or any JSON POST endpoint):
# DADIARY_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
# Telegram Bot API (errors + each payment success):
# DADIARY_ALERT_TELEGRAM_BOT_TOKEN=
# DADIARY_ALERT_TELEGRAM_CHAT_ID=

# --- Playwright E2E smoke (local / CI only) ---
# Enables /api/v1/internal/e2e/* (force-plan, alerts recorder, ops-events).
# Header: X-E2E-Secret. Leave empty in production.
# Frontend: see frontend/.env.e2e.example (E2E_SECRET must match).
# DADIARY_E2E_SECRET=local-e2e-secret

